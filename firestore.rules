rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner can read/write own profile, anyone authenticated can read others
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Incidents: any authenticated user can read, create; update only reporter or guardian
    match /incidents/{incidentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.reporterUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isGuardian == true
      );
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isGuardian == true;
    }

    // Chains: members can read, owner can update/delete
    match /chains/{chainId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Chain members: chain participants can read/write
    match /chainMembers/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Chain messages: chain participants can read/create
    match /chainMessages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Chain alerts: chain participants can read/create/update
    match /chainAlerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Families
    match /families/{familyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /familyMembers/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Activity logs: user can read own, admin can read all
    match /activityLogs/{logId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Feed
    match /feed/{feedId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
