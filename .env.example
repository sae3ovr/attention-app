# === Firebase (optional — app works in demo mode without these) ===
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# === App behavior ===
EXPO_PUBLIC_ENABLE_AUTO_DEMO=false

# === Docker Compose (backend + database) ===
POSTGRES_DB=alertio
POSTGRES_USER=alertio
POSTGRES_PASSWORD=change_me_to_a_strong_password
JWT_SECRET=change_me_to_a_random_64_char_string
NODE_ENV=development
CORS_ORIGINS=http://localhost:8081,http://localhost:8080
